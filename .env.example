# Copy this file to .env and fill in your own values.
# .env is gitignored; this file (.env.example) is the committed template.
# Every value here can still be overridden per-run with the matching CLI flag.

# MJPEG stream URLs for the two ESP32 cameras.
# EYE_STREAM_URL feeds --eye-source/--left-source (eye-facing camera, STA unit).
# FORWARD_STREAM_URL feeds --forward-source/--right-source (forward camera, AP unit).
EYE_STREAM_URL=http://192.168.4.2/stream
FORWARD_STREAM_URL=http://192.168.4.1/stream

# Calibration profile: child or adult
PROFILE=child

# dual_stream_web.py web server
WEB_PORT=5000
OUTPUT_DIR=recordings
