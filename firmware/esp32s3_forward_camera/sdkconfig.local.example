# Copy this file to sdkconfig.local (gitignored) and fill in your own Wi-Fi
# credentials. It's merged on top of sdkconfig.defaults automatically by
# CMakeLists.txt, so you don't need to run menuconfig or edit the checked-in
# defaults just to set a real network.
#
# This board is normally the AP unit (creates the hotspot the eye camera joins):
CONFIG_WIFI_ROLE_AP=y
CONFIG_AP_SSID="YourNetworkName"
CONFIG_AP_PASSWORD="YourPassword"

# If you're instead building this board as the STA, comment the AP lines
# above and uncomment these:
# CONFIG_WIFI_ROLE_STA=y
# CONFIG_WIFI_SSID="YourNetworkName"
# CONFIG_WIFI_PASSWORD="YourPassword"
